{
  "name": "agentgate",
  "version": "0.0.1",
  "private": true,
  "description": "x402 middleware & marketplace for AI agent API payments",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test && vitest run --config vitest.config.ts",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
