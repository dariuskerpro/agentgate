    "dev": "turbo dev",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.5.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4",
    "yaml": "^2.8.2"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
